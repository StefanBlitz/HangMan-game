<UserControl x:Class="Hangman.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <DockPanel Background="Aqua">
            <Menu DockPanel.Dock="Top" FontSize="14" Padding="2">
                <MenuItem Header="_File">
                    <MenuItem Header="_New Game" Command="{Binding NewGameCommand}" InputGestureText="Ctrl+N"/>
                    <MenuItem Header="_Open Game" Command="{Binding OpenLoadPanelCommand}" InputGestureText="Ctrl+O"/>
                    <MenuItem Header="_Save Game" Command="{Binding SaveGameCommand}" InputGestureText="Ctrl+S"/>
                    <MenuItem Header="_Statistics" Command="{Binding ShowStatsCommand}"/>
                    <Separator/>
                    <MenuItem Header="_Cancel" Command="{Binding CancelCommand}"/>
                </MenuItem>
                <MenuItem Header="_Categories" ItemsSource="{Binding Categories}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}"/>
                            <Setter Property="Command" Value="{Binding DataContext.NewGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_About" Command="{Binding AboutCommand}"/>
                </MenuItem>
            </Menu>

            <Grid Margin="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#44000000" Padding="15">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentUser.Name}" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <Image Source="{Binding CurrentUser.ImagePath}" Width="120" Height="120" Margin="0,10" Stretch="UniformToFill"/>
                        <Separator Margin="0,10"/>
                        <TextBlock Text="{Binding SelectedCategory, StringFormat='Category: {0}'}" FontSize="16" Foreground="White"/>
                        <TextBlock Text="{Binding Level, StringFormat='Streak: {0}/3'}" FontSize="20" FontWeight="Bold" Foreground="Yellow" Margin="0,5"/>
                        <TextBlock Text="{Binding TimeLeft, StringFormat='Time: {0}s'}" FontSize="18" Foreground="Red" FontWeight="Bold"/>
                        <Image Source="{Binding HangmanImage}" Height="250" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="{Binding DisplayWord}" FontSize="50" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30" FontFamily="Consolas"/>
                    <ItemsControl ItemsSource="{Binding LifeIndicators}" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Width="35" Height="35" Margin="2" IsEnabled="False" FontSize="18" FontWeight="Bold" Background="White"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding Letters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" MaxWidth="500"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Character}" Command="{Binding DataContext.GuessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Character}" IsEnabled="{Binding IsEnabled}" Width="40" Height="40" Margin="4" FontSize="18" FontWeight="Bold"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </DockPanel>

        <Grid Background="#AA000000" Visibility="{Binding IsLoadPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <Border Background="White" Width="400" Height="500" CornerRadius="10" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="Select a Save to Load" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    <ListBox ItemsSource="{Binding UserSaves}" SelectedItem="{Binding SelectedSave}" DisplayMemberPath="SaveName" Height="300" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Load" Command="{Binding LoadSelectedSaveCommand}" Width="100" Height="40" Margin="10" Background="Green" Foreground="White" FontWeight="Bold"/>
                        <Button Content="Close" Command="{Binding CloseLoadPanelCommand}" Width="100" Height="40" Margin="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>